rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserRole() {
      return firebase.firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserRole() == 'ADMIN';
    }

    // Product images: public read, admin write
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Invoice images: admin only (for privacy)
    match /invoices/{allPaths=**} {
      allow read, write: if isAdmin();
    }

    // Brand/Category icons: public read, admin write
    match /categories/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /brands/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User profile images (if any)
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth.uid == userId || isAdmin();
    }
  }
}
