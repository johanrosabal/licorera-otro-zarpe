rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == 'ADMIN';
    }

    function isRepartidor() {
      return isSignedIn() && getUserRole() == 'REPARTIDOR';
    }

    // ─── PUBLIC CATALOG (no auth required) ──────────────────────────────────

    // Products: anyone can read active products
    match /products/{productId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      // Allow users to update stock during checkout transaction
      allow update: if isAdmin() || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'updatedAt', 'updatedBy']));

      // Reviews: anyone can read; authenticated users can submit
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAdmin();
      }
    }

    // Categories, Brands, Settings, Notifications: public read; admin write
    match /categories/{categoryId} { allow read: if true; allow write: if isAdmin(); }
    match /brands/{brandId} { allow read: if true; allow write: if isAdmin(); }
    match /settings/{document} { allow read: if true; allow write: if isAdmin(); }
    match /notifications/{notificationId} { allow read: if true; allow write: if isAdmin(); }
    
    // System Error Logs
    match /appErrors/{errorId} {
      allow create: if isSignedIn();
      allow read, write: if isAdmin();
    }

    // ─── AUTHENTICATED USERS ─────────────────────────────────────────────────

    // Users: each user reads/updates their own doc; admins can read/update all
    // Clients can 'get' other users (to see delivery person names) but not list them all.
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /favorites/{productId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /carts/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Orders: authenticated users can read to calculate next invoice number;
    // only owners/admins can read full details (usually handled by app logic, but rules should be safe)
    // For now, allow read to all signed in users to fix the checkout block.
    match /orders/{orderId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn();
      allow update: if isAdmin() || (isRepartidor() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['repartidorAsignadoId', 'status']));
      allow delete: if isAdmin();
    }

    // ─── ADMIN & STAFF ONLY ──────────────────────────────────────────────────

    // Inventory movements: admins read/write; users create during checkout
    match /inventoryMovements/{movementId} {
      allow read: if isAdmin() || isRepartidor();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /purchases/{purchaseId} { allow read, write: if isAdmin(); }
    match /suppliers/{supplierId} { allow read, write: if isAdmin(); }
    match /productCostHistory/{historyId} {
      allow read, create: if isAdmin();
      allow update, delete: if false; 
    }

    // Payment & Bank info: needed at checkout
    match /paymentMethods/{methodId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /bankAccounts/{accountId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /banks/{bankId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /deliveryFees/{feeId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /unitsOfMeasure/{docId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
  }
}
